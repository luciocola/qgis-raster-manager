      <item row="1" column="2">
       <widget class="QPushButton" name="btnBrowseTTL">
        <property name="text">
         <string>Browse...</string>
        </property>
        <property name="maximumWidth">
         <number>100</number>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="groupBoxOptions">
     <property name="title">
      <string>Import Options</string>
     </property>
     <layout class="QVBoxLayout" name="verticalLayout_2">
      <item>
       <layout class="QHBoxLayout" name="horizontalLayout">
        <item>
         <widget class="QLabel" name="labelOutput">
          <property name="text">
           <string>Output Directory:</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QLineEdit" name="txtOutputPath"/>
        </item>
        <item>
         <widget class="QPushButton" name="btnBrowseOutput">
          <property name="text">
           <string>Browse...</string>
          </property>
          <property name="maximumWidth">
           <number>100</number>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <widget class="QCheckBox" name="chkWarp">
        <property name="text">
         <string>Warp image for proper display (recommended)</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="chkOrthorectify">
        <property name="text">
         <string>Orthorectify using GCPs (advanced geometric correction)</string>
        </property>
        <property name="checked">
         <bool>false</bool>
        </property>
        <property name="toolTip">
         <string>Apply polynomial transformation using Ground Control Points for precise geometric correction. Recommended for aerial/satellite imagery.</string>
        </property>
       </widget>
      </item>
      <item>
       <layout class="QHBoxLayout" name="horizontalLayout_3">
        <item>
         <widget class="QLabel" name="labelTransform">
          <property name="text">
           <string>Transformation Order:</string>
          </property>
          <property name="enabled">
           <bool>false</bool>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QComboBox" name="cmbTransformOrder">
          <property name="enabled">
           <bool>false</bool>
          </property>
          <property name="toolTip">
           <string>Polynomial order for orthorectification. Higher orders fit complex distortions but require more GCPs.</string>
          </property>
          <item>
           <property name="text">
            <string>1st Order (3+ GCPs, affine)</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>2nd Order (6+ GCPs)</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>3rd Order (10+ GCPs)</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>TPS (Thin Plate Spline)</string>
           </property>
          </item>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <layout class="QHBoxLayout" name="horizontalLayout_2">
        <item>
         <widget class="QLabel" name="labelResample">
          <property name="text">
           <string>Resampling Method:</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QComboBox" name="cmbResample">
          <item>
           <property name="text">
            <string>Cubic (best quality)</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>Lanczos (high quality)</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>Bilinear</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>Nearest Neighbor (fastest)</string>
           </property>
          </item>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <widget class="QCheckBox" name="chkAddToMap">
        <property name="text">
         <string>Add result to map canvas</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="chkExportJP2">
        <property name="text">
         <string>Export as JPEG2000 (.jp2) instead of GeoTIFF</string>
        </property>
        <property name="checked">
         <bool>false</bool>
        </property>
        <property name="toolTip">
         <string>Export as JPEG2000 format with better compression (20-30% smaller) and native QGIS support. Requires heif-enc or GDAL JPEG2000 driver.</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="chkGenerateRDF">
        <property name="text">
         <string>Generate RDF/TTL provenance file</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
        <property name="toolTip">
         <string>Create an RDF Turtle file with processing provenance metadata (W3C PROV-O format)</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
