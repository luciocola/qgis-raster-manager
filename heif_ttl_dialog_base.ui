      </item>
      <item row="0" column="2">
       <widget class="QPushButton" name="btnBrowseHEIF">
        <property name="text">
         <string>Browse...</string>
        </property>
        <property name="maximumWidth">
         <number>100</number>
        </property>
       </widget>
      </item>
      <item row="0" column="3">
       <widget class="QPushButton" name="btnShowStructure">
        <property name="text">
         <string>Show Structure</string>
        </property>
        <property name="maximumWidth">
         <number>120</number>
        </property>
        <property name="toolTip">
         <string>Display complete HEIF/HEVC file structure including metadata, images, and thumbnails</string>
        </property>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QLabel" name="labelTTL">
        <property name="text">
         <string>TTL Metadata:</string>
        </property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QLineEdit" name="txtTTLPath"/>
