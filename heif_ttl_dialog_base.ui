   </rect>
  </property>
  <property name="windowTitle">
   <string>HEIF/TTL Imagery Importer</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="QGroupBox" name="groupBoxFiles">
     <property name="title">
      <string>Input Files</string>
     </property>
     <layout class="QGridLayout" name="gridLayout">
      <item row="0" column="0">
       <widget class="QLabel" name="labelHEIF">
        <property name="text">
         <string>HEIF Image:</string>
        </property>
       </widget>
      </item>
      <item row="0" column="1">
